# Application
APP_ENV=development
HTTP_ADDR=:8080
AUTH_SECRET=vendorbridge-dev-secret-change-me

# Local Postgres connection for `go run`
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=vendorbridge
POSTGRES_USER=vendorbridge
POSTGRES_PASSWORD=vendorbridge
DATABASE_URL=postgres://vendorbridge:vendorbridge@localhost:5432/vendorbridge?sslmode=disable

# Docker Compose connection for the app container
DATABASE_URL_DOCKER=postgres://vendorbridge:vendorbridge@db:5432/vendorbridge?sslmode=disable

